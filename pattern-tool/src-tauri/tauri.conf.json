{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pattern Tool",
  "version": "0.1.0",
  "identifier": "com.abclabs.pattern-tool",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "sh -c 'if curl -fsS http://localhost:3000 >/dev/null 2>&1; then exit 0; fi; exec npm run dev -- --port 3000'",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pattern Tool",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
